# ──────────────────────────────────────────────────────────────────────────────
#  Variables de entorno — copiar a .env y completar valores reales
#  NUNCA subir .env al repositorio
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=newsroom
POSTGRES_PASSWORD=changeme
POSTGRES_DB=newsroom_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://newsroom:changeme@postgres:5432/newsroom_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace_with_a_strong_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
AZURE_OPENAI_VERSION=2024-12-01-preview

# ── Servicio Agent (URL interna Docker) ───────────────────────────────────────
AGENT_SERVICE_URL=http://agent:8001

# ── Token interno (worker → api, seguridad entre servicios) ──────────────────
INTERNAL_TOKEN=replace_with_a_strong_random_secret

# ── URL interna para el worker ────────────────────────────────────────────────
API_SERVICE_URL=http://api:8000

# ── Configuración general ─────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
